# Copy to .env for local development.
# Never commit real API keys.

# Recommended if you want to use Google Cloud credits:
# 1. Enable the Vertex AI API in your Google Cloud project.
# 2. Run: gcloud auth application-default login
# 3. Set your project below.
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_MODEL=gemini-2.5-flash

# Alternative API-key mode for Gemini Developer API / AI Studio.
# This may not use your Google Cloud credits the same way Vertex AI does.
# GOOGLE_GENAI_USE_VERTEXAI=false
# GOOGLE_API_KEY=your-gemini-api-key
